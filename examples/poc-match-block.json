{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/post-new.php",
  "login": true,
  "preferredVersions": { "php": "8.0", "wp": "latest" },
  "features": { "networking": true },
  "siteOptions": {
    "blogname": "POC — Match Block",
    "blogdescription": "Real-time input matching block for WordPress"
  },
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "url",
        "url": "https://github.com/flexseth/match-block/releases/download/v1.1.0/match-block.zip",
        "caption": "Match Block"
      },
      "options": { "activate": true }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "syntax-highlighter-evolved"
      },
      "options": { "activate": true }
    },
    {
      "step": "wp-cli",
      "command": "wp post create --post_title='Match Block POC' --post_status='publish' --post_type='post' --post_content='<!-- wp:match-block/match-block /-->'"
    }
  ]
}
